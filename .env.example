# ---- Choose ONE free LLM provider (Groq recommended — generous free tier) ----

# Option A: Groq (free, ~14k requests/day) — get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Option B: Gemini — get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Provider is auto-selected (Groq if its key is set). Force one if you like:
# LLM_PROVIDER=groq        # or: gemini
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.5-flash-lite
